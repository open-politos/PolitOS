# PolitOS — Environment Variables
# Copy this file to .env and fill in your values.

# LLM API Keys (configure the one matching your llm.provider in party.config.yaml)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OLLAMA_API_BASE=http://localhost:11434

# ChromaDB (local by default, no config needed)
# CHROMA_PERSIST_DIR=./data/chromadb

# Server
POLITOS_HOST=0.0.0.0
POLITOS_PORT=8000
